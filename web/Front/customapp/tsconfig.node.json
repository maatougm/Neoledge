{
  "extends": "@vue/tsconfig/tsconfig.json",
  "include": [
    "vite.config.*",
    "vitest.config.*",
    "cypress.config.*",
    "playwright.config.*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": [
      "node"
    ],
    "target": "ESNext",
    "module":"ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "ignoreDeprecations": "5.0",
  }
}