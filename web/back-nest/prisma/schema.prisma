  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    AppUser        @relation("WikiPageAuthor", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parent    WikiPage?      @relation("WikiHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
