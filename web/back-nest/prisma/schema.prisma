// ─── Sprint 2: RACI + Handover ────────────────────────────────────────────────

model ActivityRaci {
  id                  Int    @id @default(autoincrement())
  phase               String @db.VarChar(100)
  activityCode        String @unique @db.VarChar(100)
  activityLabel       String @db.VarChar(500)
  responsibleTeamCode String @db.VarChar(500)
  approverTeamCode    String @db.VarChar(500)
  consultedTeams      String @default("") @db.VarChar(500)
  informedTeams       String @default("") @db.VarChar(500)
  order               Int    @default(0)

  @@index([phase])
  @@map("ActivityRacis")
}

model Handover {
  id               String    @id @default(uuid())
  projectId        String
  fromTeamCode     String    @db.VarChar(50)
  toTeamCode       String    @db.VarChar(50)
  phase            String    @db.VarChar(100)
  status           String    @default("Draft") @db.VarChar(50)
  acceptedAt       DateTime?
  acceptedByUserId String?   @db.VarChar(36)
  rejectionReason  String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  criteria HandoverCriterion[]

  @@index([projectId])
  @@index([status])
  @@map("Handovers")
}

// ─── Cahier des Charges Feedback (AI learning from rejected documents) ───────

model CahierFeedback {
  id        String   @id @default(uuid())
  projectId String
  userId    String?
  status    String   @default("rejected") @db.VarChar(20)  // 'approved' | 'rejected'
  comment   String   @db.Text                                // User explanation
  section   String?  @db.VarChar(100)                        // Which section was problematic
  aiModel   String?  @db.VarChar(50)                         // Model that generated the doc
  createdAt DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    AppUser? @relation("CahierFeedbackUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([createdAt])
  @@map("CahierFeedback")
}

model HandoverCriterion {
  id           String    @id @default(uuid())
  handoverId   String
  code         String    @db.VarChar(100)
  label        String    @db.VarChar(500)
  isDone       Boolean   @default(false)
  doneAt       DateTime?
  doneByUserId String?   @db.VarChar(36)
  evidenceUrl  String?   @db.VarChar(1000)

  handover Handover @relation(fields: [handoverId], references: [id], onDelete: Cascade)

  @@index([handoverId])
  @@map("HandoverCriteria")
}
