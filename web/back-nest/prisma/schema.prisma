  projectId     String
  workPackageId String?
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  date          DateTime  @db.Date
  isReached     Boolean   @default(false)
  color         String?   @db.VarChar(16)
  position      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workPackage WorkPackage? @relation(fields: [workPackageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([projectId, date])
  @@map("Milestones")
}

model GanttBaseline {
  id             String    @id @default(uuid())
  projectId      String
  workPackageId  String
  snapshotDate   DateTime  @default(now())
  snapshotName   String    @db.VarChar(120)
  startDate      DateTime? @db.Date
  dueDate        DateTime? @db.Date
  estimatedHours Decimal?  @db.Decimal(8, 2)
  percentDone    Int       @default(0)
  createdById    String

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workPackage WorkPackage @relation(fields: [workPackageId], references: [id], onDelete: Cascade)
  createdBy   AppUser     @relation("GanttBaselineCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([projectId, snapshotName, workPackageId])
  @@index([projectId, snapshotName])
  @@index([workPackageId])
  @@map("GanttBaselines")
}

model TimeEntry {
  id            String    @id @default(uuid())
  userId        String
  projectId     String
  workPackageId String?
  hours         Decimal   @db.Decimal(6, 2)
  spentOn       DateTime  @db.Date
  activity      String    @default("development") @db.VarChar(32)
  comment       String?   @db.Text
  isBillable    Boolean   @default(true)
  lockedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        AppUser      @relation("TimeEntryUser", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workPackage WorkPackage? @relation(fields: [workPackageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, spentOn])
  @@index([projectId, spentOn])
  @@index([workPackageId])
  @@map("TimeEntries")
}

model HourlyRate {
  id        String    @id @default(uuid())
  userId    String
  projectId String?
  rate      Decimal   @db.Decimal(10, 2)
  currency  String    @default("EUR") @db.VarChar(8)
  validFrom DateTime  @db.Date
  validTo   DateTime? @db.Date
  createdAt DateTime  @default(now())

  user    AppUser  @relation("HourlyRateUser", fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // NOTE: MySQL/MariaDB treats NULL as distinct in UNIQUE indexes, so
  // (userId, NULL, validFrom) does not collide with another (userId, NULL, validFrom) row
  // at the DB level. Application code must use findFirst + create (never upsert) for global
  // rates (projectId = NULL) to prevent duplicate global-rate rows.
  @@unique([userId, projectId, validFrom])
  @@index([userId, projectId, validFrom])
  @@map("HourlyRates")
}

model ProjectBudget {
  id             String   @id @default(uuid())
  projectId      String   @unique
  laborBudget    Decimal  @default(0) @db.Decimal(14, 2)
  materialBudget Decimal  @default(0) @db.Decimal(14, 2)
  currency       String   @default("EUR") @db.VarChar(8)
  notes          String?  @db.Text
  version        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems BudgetLineItem[]

  @@map("ProjectBudgets")
}

model BudgetLineItem {
  id          String   @id @default(uuid())
  budgetId    String
  description String   @db.VarChar(255)
  type        String   @default("material") @db.VarChar(16)
  kind        String   @default("actual") @db.VarChar(16)
  unitCost    Decimal  @db.Decimal(14, 2)
  units       Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(14, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  budget ProjectBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId, position])
  @@index([budgetId, kind])
  @@map("BudgetLineItems")
}

model WikiPage {
  id        String   @id @default(uuid())
  projectId String
  title     String   @db.VarChar(255)
