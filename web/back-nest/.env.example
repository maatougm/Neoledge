# ─────────────────────────────────────────────────────────────────────────────
# NeoLeadge Deployment Manager — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL — use the dev container started by `docker compose up postgres`
# or any local Postgres 14+ instance.
DATABASE_URL="postgresql://neoleadge:neoleadge@127.0.0.1:5432/neoleadge?schema=public"

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret-minimum-32-chars"
JWT_EXPIRES_IN="8h"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5122

# ── AI / Transcription (optional) ────────────────────────────────────────────
TRANSCRIPTION_URL="http://localhost:8000"
TRANSCRIPTION_SECRET="changeme-dev-secret"
AI_PROVIDER="openai"           # openai | gemini
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# ── Azure OpenAI (optional — leave empty to use standard OpenAI) ─────────────
AZURE_OPENAI_ENDPOINT=""       # e.g. https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=""     # e.g. gpt-4o-mini
AZURE_OPENAI_API_VERSION="2024-08-01-preview"

# ── Cahier des Charges AI Model ──────────────────────────────────────────────
CAHIER_AI_MODEL="gpt-4o-mini"  # Model for cahier des charges generation
CAHIER_GEMINI_MODEL="gemini-1.5-flash"

# ── Email (optional — set EMAIL_ENABLED=true to send real emails) ─────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="NeoLeadge <noreply@neoleadge.com>"
EMAIL_ENABLED=false
