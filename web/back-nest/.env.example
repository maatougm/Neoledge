# ─────────────────────────────────────────────────────────────────────────────
# NeoLeadge Deployment Manager — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# MariaDB via XAMPP (default root with no password)
DATABASE_URL="mysql://root@localhost:3306/NeoLeadgeDeployment"
# With password:
# DATABASE_URL="mysql://root:yourpassword@localhost:3306/NeoLeadgeDeployment"

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret-minimum-32-chars"
JWT_EXPIRES_IN="8h"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5122

# ── AI / Transcription (optional) ────────────────────────────────────────────
TRANSCRIPTION_URL="http://localhost:8000"
TRANSCRIPTION_SECRET="changeme-dev-secret"
OPENAI_API_KEY=""

# ── Email (optional — set EMAIL_ENABLED=true to send real emails) ─────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="NeoLeadge <noreply@neoleadge.com>"
EMAIL_ENABLED=false
