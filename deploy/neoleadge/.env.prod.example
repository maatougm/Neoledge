# ============================================================================
# NeoLeadge — production env template
# Copy to `.env.prod` on the server and fill in every secret.
# Every variable referenced by docker-compose.prod.yml is listed here.
# Values marked «REQUIRED» have no safe default — the stack will not work
# (or will be insecure) until you set them.
# ============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_USER=neoleadge
DB_NAME=neoleadge
# «REQUIRED» strong random password (e.g. `openssl rand -hex 24`)
DB_PASSWORD=change-me-strong-random-password

# ── JWT auth ──────────────────────────────────────────────────────────────
# «REQUIRED» 32+ char random secret. Pinned to HS256. Rotating this
# invalidates every issued token (forces all users to re-login).
JWT_SECRET=change-me-at-least-32-random-chars-aaaaaaaaaaaaaaaa
JWT_EXPIRES_IN=7d

# ── AI master switch + primary provider ────────────────────────────────────
# AI_ENABLED gates ALL AI features. Set true in prod.
AI_ENABLED=true
# Primary provider for single-shot + agent paths: zai | openai | gemini
AI_PROVIDER=zai
# Model for non-Z.AI providers in single-shot mode.
AI_MODEL=gpt-4o-mini
# Optional per-feature model overrides (leave blank to use AI_MODEL).
CAHIER_AI_MODEL=
CAHIER_GEMINI_MODEL=

# OpenAI (used as the agent fallback when AI_PROVIDER=zai). «REQUIRED if you
# want the fallback chain to work» — a Z.AI 429/outage falls through to this.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Gemini (single-shot only — not supported in agent mode).
GEMINI_API_KEY=

# ── Z.AI (the default primary provider) ─────────────────────────────────────
# «REQUIRED when AI_PROVIDER=zai» — also drives the agent loop.
AI_FALLBACK_API_KEY=
AI_FALLBACK_BASE_URL=https://api.z.ai/api/coding/paas/v4
AI_FALLBACK_MODEL=glm-4.5-air
AI_FALLBACK_PROVIDER=openai

# ── Agent mode ──────────────────────────────────────────────────────────────
# Comma list or "all": transcript,cahier,backlog,assignment
AI_AGENT_MODE=all
# Toggles the real-time live-meeting copilot agent.
LIVE_MEETING_COPILOT=on

# ── Demo video only (TEMPORARY) ─────────────────────────────────────────────
# When "on", the live copilot replays a fixed, deterministic checklist for the
# Rapido demo project instead of calling the AI (no tokens, no latency). It is
# a strict no-op for every other project/session. Set to "off" after recording.
# DEMO_COPILOT_PROJECT_ID defaults to the Rapido seed id when blank.
DEMO_COPILOT_MODE=off
DEMO_COPILOT_PROJECT_ID=

# ── Phase 1-5 orchestra flags (default ON in prod — see docs/AI_MODULE_GUIDE) ─
# Cahier uses the planner-worker single-shot path (vs the slower agent loop).
CAHIER_USE_PLANNER=on
# Skip the cahier self-critique pass (saves ~90s; safe with planner-worker).
CAHIER_PLANNER_SKIP_CRITIQUE=on
# Register pgvector semantic-retrieval tools alongside keyword tools.
CAHIER_USE_SEMANTIC_RETRIEVAL=on
BACKLOG_USE_PLANNER=on
ASSIGNMENT_USE_PLANNER=on

# ── Embeddings (pgvector / self-hosted multilingual-e5-small) ───────────────
# Per-call timeout to the FastAPI /embed endpoint (ms).
EMBEDDING_TIMEOUT_MS=15000

# ── Transcription service (FastAPI: faster-whisper + e5 embeddings) ─────────
# «REQUIRED» shared secret between the server + transcription containers.
TRANSCRIPTION_SECRET=change-me-32-byte-random-hex
# Whisper model: base | small | medium | large-v3 (bigger = better, slower).
WHISPER_MODEL=base
TRANSCRIPTION_DEVICE=cpu
TRANSCRIPTION_COMPUTE_TYPE=int8

# AssemblyAI Universal-2 — primary STT + diarization for live meetings.
# When blank, falls back to the local faster-whisper stack.
ASSEMBLYAI_API_KEY=

# ── Audio retention ─────────────────────────────────────────────────────────
# Purge meeting recordings older than N days. 0 = keep indefinitely.
MEETING_AUDIO_RETENTION_DAYS=90

# ── Per-project daily AI token budget ───────────────────────────────────────
# 0 / unset = unlimited. Exceeding it returns a BadGateway quota error.
AI_MAX_TOKENS_PER_PROJECT_PER_DAY=0

# ── CORS + rate limiting ────────────────────────────────────────────────────
# «REQUIRED» comma-separated allowed origins (no trailing slash).
CORS_ORIGINS=https://neoleadge.pythagore-init.com
# Comma-separated IPs exempt from the global throttler (leave blank in prod).
THROTTLER_WHITELIST=

# ── Email (SMTP) ────────────────────────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Public base URL used to build links in emails (password-reset link, etc.).
# «REQUIRED for working reset emails» — defaults to http://localhost:5173 in
# code, which is wrong in prod. Set to the public origin.
FRONTEND_URL=https://neoleadge.pythagore-init.com
